# LLM Configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your-api-key-here

# Model assignments for different tasks
GATHERER_MODEL=gemini-2.5-flash
ANALYZER_MODEL=gemini-2.5-pro
SPEC_WRITER_MODEL=gemini-2.5-pro
VALIDATOR_MODEL=gemini-2.5-pro

# Execution mode
DEFAULT_MODE=full

# Output paths
OUTPUT_DIR=output
LOGS_DIR=logs

# Logging
LOG_LEVEL=INFO

# Debug/Verbose
DEBUG=false
VERBOSE=false

# Supported Providers:
# - gemini (Google Gemini)
# - claude (Anthropic Claude)
# - openai (OpenAI GPT)
# - ollama (Local Ollama)
# - groq (Groq)
# - huggingface (HuggingFace)
